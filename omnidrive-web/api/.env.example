# ──────────────────────────────────────────────
# OmniDrive API – Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ── Auth ──────────────────────────────────────
# JWT secret for signing tokens (generate: python -c "import secrets; print(secrets.token_urlsafe(32))")
OMNIDRIVE_JWT_SECRET=your-jwt-secret-here

# ── Google Drive ──────────────────────────────
# Path (inside container) or JSON string for service-account credentials
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── Folderfort ────────────────────────────────
FOLDERFORT_TOKEN=your-folderfort-api-token
FOLDERFORT_EMAIL=your-folderfort-email@example.com

# ── CORS ──────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,https://omnidrive.sujeto10.com

# ── Logging ───────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
OMNIDRIVE_LOG_LEVEL=INFO
# Log format: json | text
OMNIDRIVE_LOG_FORMAT=json

# ── Optional / Future ─────────────────────────
# OPENAI_API_KEY=sk-...
# DATABASE_URL=postgresql://user:password@host:port/db
# REDIS_URL=redis://host:port
# SENTRY_DSN=https://...
