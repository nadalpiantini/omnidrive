# OmniDrive Environment Variables Template
# Copy this file to .env and fill in your values

# ============================================
# SUPABASE DATABASE (Required)
# ============================================
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR-ANON-KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY
SUPABASE_DATABASE_PASSWORD=YOUR-DB-PASSWORD
PROJECT_PREFIX=omnidrive_

# ============================================
# AI SERVICES (Required for RAG)
# ============================================
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# ============================================
# GOOGLE DRIVE (Required)
# ============================================
# Create service account at https://console.cloud.google.com
# Download JSON and paste content below (single line, escaped)
GOOGLE_SERVICE_ACCOUNT_JSON='{"type": "service_account", "project_id": "...", "private_key_id": "...", "private_key": "...", "client_email": "...", "client_id": "...", "auth_uri": "...", "token_uri": "...", "auth_provider_x509_cert_url": "...", "client_x509_cert_url": "..."}'

# ============================================
# FOLDERFORT (Required)
# ============================================
FOLDERFORT_EMAIL=your-email@example.com
FOLDERFORT_PASSWORD=your-password
FOLDERFORT_API_URL=https://na2.folderfort.com

# ============================================
# RAILWAY - Backend Deployment (Required)
# ============================================
RAILWAY_TOKEN=your-railway-token
RAILWAY_PROJECT_ID=your-project-id

# ============================================
# VERCEL - Frontend Deployment (Required)
# ============================================
VERCEL_TOKEN=your-vercel-token
VERCEL_ORG_ID=your-org-id
VERCEL_PROJECT_ID=your-project-id

# ============================================
# CLOUDFLARE - DNS (Required)
# ============================================
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_API_TOKEN=your-api-token
CLOUDFLARE_ZONE_ID=your-zone-id

# ============================================
# BACKEND CONFIGURATION (Railway)
# ============================================
PYTHON_VERSION=3.10
PORT=8000
FRONTEND_URL=https://omnidrive.sujeto10.com
APP_NAME=OmniDrive
APP_VERSION=1.0.0
ENVIRONMENT=production
LOG_LEVEL=info

# ============================================
# FRONTEND CONFIGURATION (Vercel)
# ============================================
NEXT_PUBLIC_API_URL=https://api.omnidrive.sujeto10.com
NEXT_PUBLIC_WS_URL=wss://api.omnidrive.sujeto10.com/ws
NEXT_PUBLIC_APP_NAME=OmniDrive
NEXT_PUBLIC_APP_URL=https://omnidrive.sujeto10.com
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# ============================================
# MONITORING (Optional)
# ============================================
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=your-analytics-id

# ============================================
# DEVELOPMENT (Local only)
# ============================================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
